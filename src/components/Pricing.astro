---
const included = [
  'Plataforma personalizada',
  'Hosting incluido',
  'Mantenimiento continuo',
  'Soporte directo',
  'Nuevas funciones',
];

const excluded = [
  'Sin setup fee',
  'Sin costo por usuario',
  'Sin módulos adicionales',
  'Sin sorpresas en la factura',
];
---

<div class="section" id="precios">
  <div class="section-header fade-in">
    <p class="section-eyebrow">Precios</p>
    <h2>Un precio. Sin sorpresas.</h2>
  </div>
  <div class="pricing-wrap">
    <div class="fade-in">
      <div class="pricing-card">
        <div class="price-amt">$2,500<span> MXN</span></div>
        <div class="price-period">/ mes</div>
        <div class="price-meta">IVA incluido · Sin costo de inicio · Contrato mínimo 24 meses</div>
        <hr class="price-rule" />
        <ul class="price-included">
          {included.map((item) => <li>{item}</li>)}
        </ul>
        <hr class="price-rule" />
        <ul class="price-excluded">
          {excluded.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="ai-addon">
        <div>
          <div class="addon-badge">Add-on opcional</div>
          <div class="addon-title">Módulo IA</div>
          <div class="addon-desc">
            Generación de propuestas, transcripción de voz, respuestas
            inteligentes y resúmenes automáticos. Se integra directo
            a tu plataforma.
          </div>
        </div>
        <div class="addon-price">
          <span class="addon-amt">+$1,000</span>
          <span class="addon-per">MXN / mes</span>
        </div>
      </div>
    </div>

    <div class="price-context fade-in">
      <div class="price-big">
        Sin cobro de desarrollo.<br />
        <span>Solo pagas tu mensualidad desde el día uno.</span>
      </div>
      <p>
        Las agencias tradicionales cobran entre $80,000 y $300,000 MXN solo por
        construir la plataforma. Eso sin contar el mantenimiento anual. Nosotros
        hacemos algo diferente: sin cobro de desarrollo, sin setup fee. Tu primer
        pago mensual es tu compromiso, y nosotros nos ponemos a construir.
      </p>
      <a href="/precios">Ver todos los detalles →</a>
    </div>
  </div>
</div>

<style>
  .pricing-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  .pricing-card {
    border: 2px solid var(--color-carbon);
    border-radius: 16px;
    padding: 44px 40px;
    background: var(--color-carbon);
    color: var(--color-crema);
  }

  .price-amt {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 68px);
    font-weight: 700;
    letter-spacing: -3px;
    line-height: 1;
    margin-bottom: 4px;
  }

  .price-amt span {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.3px;
    opacity: 0.65;
  }

  .price-period {
    font-size: 16px;
    opacity: 0.5;
    font-family: var(--font-body);
    margin-top: 4px;
  }

  .price-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 32px;
    margin-top: 10px;
  }

  .price-rule {
    border: none;
    border-top: 1px solid rgba(255, 249, 240, 0.1);
    margin-bottom: 24px;
  }

  .price-included {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin-bottom: 24px;
    padding: 0;
  }

  .price-included li {
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .price-included li::before {
    content: '✓';
    color: var(--color-aqua);
    font-weight: 700;
    font-size: 12px;
    flex-shrink: 0;
  }

  .price-excluded {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 0;
  }

  .price-excluded li {
    font-size: 13px;
    opacity: 0.45;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .price-excluded li::before {
    content: '×';
    font-size: 12px;
  }

  /* AI Add-on */
  .ai-addon {
    margin-top: 16px;
    border: 1.5px solid rgba(0, 184, 150, 0.35);
    border-radius: 12px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: rgba(0, 184, 150, 0.04);
  }

  .addon-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-aqua);
    border: 1px solid rgba(0, 184, 150, 0.4);
    border-radius: 20px;
    padding: 3px 10px;
    margin-bottom: 8px;
  }

  .addon-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.3px;
    margin-bottom: 6px;
  }

  .addon-desc {
    font-size: 13px;
    line-height: 1.65;
    opacity: 0.62;
    max-width: 340px;
  }

  .addon-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .addon-amt {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--color-aqua);
  }

  .addon-per {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-top: 4px;
  }

  /* Context column */
  .price-context {
    padding-top: 4px;
  }

  .price-big {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .price-big span {
    color: var(--color-guayaba);
  }

  .price-context p {
    font-size: 15px;
    line-height: 1.75;
    opacity: 0.72;
    margin-bottom: 24px;
  }

  .price-context a {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-carbon);
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.65;
  }

  @media (max-width: 900px) {
    .pricing-wrap {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 600px) {
    .pricing-card {
      padding: 32px 24px;
    }
  }
</style>
