---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const plans = [
  {
    name: 'Plataforma',
    price: '$2,500',
    period: '/mes',
    description: 'Tu plataforma a la medida, lista en 4 semanas. Todo incluido.',
    features: [
      'Plataforma personalizada',
      'Hosting incluido',
      'Mantenimiento continuo',
      'Soporte directo',
      'Nuevas funciones',
      'Sin costo de inicio',
    ],
    cta: 'Agenda tu demo',
    highlighted: true,
  },
  {
    name: 'Plataforma + IA',
    price: '$3,500',
    period: '/mes',
    description: 'Todo lo anterior más módulo de inteligencia artificial integrado.',
    features: [
      'Todo lo del plan Plataforma',
      'Generación de propuestas',
      'Transcripción de voz',
      'Respuestas inteligentes',
      'Resúmenes automáticos',
      'Integrado a tu plataforma',
    ],
    cta: 'Agenda tu demo',
    highlighted: false,
  },
  {
    name: 'A la medida',
    price: 'Personalizado',
    period: '',
    description: 'Para negocios con necesidades más complejas o integraciones especiales.',
    features: [
      'Todo lo anterior',
      'Integraciones a medida',
      'Múltiples plataformas',
      'API y webhooks',
      'SLA garantizado',
      'Soporte dedicado',
    ],
    cta: 'Platiquemos',
    highlighted: false,
  },
];
---

<Layout
  title="Precios — HeyJimmi | Software a la medida desde $2,500/mes"
  description="Conoce los planes y precios de HeyJimmi. Plataformas digitales a la medida para PyMEs en México desde $2,500 MXN al mes."
>
  <section class="pt-28 pb-16 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
          Planes simples, <span class="text-primary-600">precios justos</span>
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          Sin contratos largos ni costos ocultos. Elige el plan que mejor se adapte a tu negocio y escala cuando lo necesites.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {plans.map((plan) => (
          <div class={`relative rounded-2xl p-8 ${plan.highlighted ? 'bg-primary-600 text-white ring-4 ring-primary-600 ring-offset-2 scale-105' : 'bg-white border border-gray-200'}`}>
            {plan.highlighted && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center rounded-full bg-accent-500 px-4 py-1 text-xs font-bold text-white uppercase tracking-wider">
                  Más popular
                </span>
              </div>
            )}
            <h3 class={`text-lg font-bold mb-2 ${plan.highlighted ? 'text-white' : 'text-dark'}`}>{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-2">
              <span class={`text-4xl font-extrabold font-heading ${plan.highlighted ? 'text-white' : 'text-dark'}`}>{plan.price}</span>
              {plan.period && <span class={`text-sm ${plan.highlighted ? 'text-primary-200' : 'text-gray-500'}`}>{plan.period} MXN</span>}
            </div>
            <p class={`text-sm mb-8 ${plan.highlighted ? 'text-primary-100' : 'text-gray-600'}`}>{plan.description}</p>

            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${plan.highlighted ? 'text-primary-200' : 'text-secondary-500'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class={`text-sm ${plan.highlighted ? 'text-primary-50' : 'text-gray-600'}`}>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href="/demo"
              class={`block w-full text-center rounded-lg px-6 py-3 text-sm font-semibold transition-colors ${
                plan.highlighted
                  ? 'bg-white text-primary-600 hover:bg-primary-50'
                  : 'bg-primary-600 text-white hover:bg-primary-700'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <p class="text-gray-500 text-sm">
          Todos los precios son en pesos mexicanos (MXN), IVA incluido. Contrato mínimo 24 meses. Sin costo de inicio.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-gray-light">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold font-heading text-dark text-center mb-12">Preguntas frecuentes</h2>
      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="font-bold text-dark mb-2">¿Hay algún costo de setup?</h3>
          <p class="text-gray-600 text-sm">No. El diseño, la construcción y la puesta en marcha de tu plataforma están incluidos. Empiezas a pagar cuando ya funciona.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="font-bold text-dark mb-2">¿Puedo cambiar de plan?</h3>
          <p class="text-gray-600 text-sm">Sí, puedes escalar o cambiar de plan en cualquier momento. Los cambios se aplican en tu siguiente ciclo de facturación.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="font-bold text-dark mb-2">¿Qué incluye el mantenimiento?</h3>
          <p class="text-gray-600 text-sm">Hosting, actualizaciones, corrección de errores y soporte directo. Si necesitas nuevas funciones, las construimos sin costo adicional dentro de tu plan.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-gray-100">
          <h3 class="font-bold text-dark mb-2">¿Hay compromiso de permanencia?</h3>
          <p class="text-gray-600 text-sm">No. Todos nuestros planes son mensuales y puedes cancelar en cualquier momento sin penalización.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
