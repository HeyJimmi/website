---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
    title: 'Chatbots inteligentes',
    description: 'Asistentes que entienden contexto, responden con naturalidad y resuelven dudas como lo haría tu mejor agente.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
    title: 'WhatsApp y web',
    description: 'Conecta tu asistente a WhatsApp Business, tu sitio web, redes sociales y más canales.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: 'Implementación rápida',
    description: 'Tu asistente está listo en días, no meses. Nos encargamos de todo el proceso técnico.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
    title: 'Métricas en tiempo real',
    description: 'Dashboard con estadísticas de conversaciones, satisfacción y rendimiento de tu asistente.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: 'Escalamiento humano',
    description: 'Cuando el asistente no puede resolver algo, transfiere la conversación a tu equipo de forma fluida.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    title: 'Seguro y confiable',
    description: 'Tus datos y los de tus clientes están protegidos con cifrado de nivel empresarial.',
  },
];

const stats = [
  { value: '95%', label: 'Satisfacción del cliente' },
  { value: '24/7', label: 'Disponibilidad' },
  { value: '< 3s', label: 'Tiempo de respuesta' },
  { value: '70%', label: 'Reducción de carga operativa' },
];

const verticals = [
  {
    href: '/para/condominios',
    title: 'Condominios',
    description: 'Automatiza la comunicación con residentes: avisos, reservaciones de amenidades, reportes de mantenimiento y más.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  },
  {
    href: '/para/academias',
    title: 'Academias',
    description: 'Asistente para inscripciones, horarios, información de cursos y atención a padres de familia y alumnos.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>`,
  },
  {
    href: '/para/medios-locales',
    title: 'Medios locales',
    description: 'Distribuye noticias, gestiona suscriptores y automatiza la interacción con tu audiencia por WhatsApp.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>`,
  },
];
---

<Layout
  title="HeyJimmi — Chatbots y Asistentes IA para Negocios en México"
  description="HeyJimmi es un AI Studio que crea chatbots y asistentes digitales inteligentes para negocios en México. Automatiza tu atención al cliente con IA."
>
  <!-- Hero Section -->
  <section class="relative pt-28 pb-20 sm:pt-36 sm:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-secondary-50"></div>
    <div class="absolute top-20 right-0 w-96 h-96 bg-primary-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700 mb-8">
          AI Studio en México
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold font-heading text-dark leading-tight mb-6">
          Tu negocio merece un asistente
          <span class="text-primary-600"> inteligente</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 leading-relaxed mb-10 max-w-2xl mx-auto">
          Creamos chatbots y asistentes digitales con IA que atienden a tus clientes 24/7 por WhatsApp y web. Diseñados para negocios en México.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/demo"
            class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3.5 text-base font-semibold text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-600/25"
          >
            Agenda tu demo gratis
          </a>
          <a
            href="/como-funciona"
            class="inline-flex items-center justify-center rounded-lg border-2 border-gray-200 bg-white px-8 py-3.5 text-base font-semibold text-dark hover:border-primary-300 hover:text-primary-600 transition-colors"
          >
            Cómo funciona
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 bg-white border-y border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold font-heading text-primary-600">{stat.value}</div>
            <div class="mt-1 text-sm text-gray-500">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark mb-4">
          Todo lo que necesitas para automatizar tu atención
        </h2>
        <p class="text-lg text-gray-600">
          Herramientas potentes, implementación sencilla y resultados desde el primer día.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="group p-8 rounded-2xl border border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-primary-100 text-primary-600 flex items-center justify-center mb-5 group-hover:bg-primary-600 group-hover:text-white transition-colors">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-lg font-bold text-dark mb-2">{feature.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works (brief) -->
  <section class="py-20 sm:py-28 bg-gray-light">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark mb-4">
          Así de fácil es empezar
        </h2>
        <p class="text-lg text-gray-600">
          De la idea al lanzamiento en días, no meses.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary-600 text-white text-xl font-bold flex items-center justify-center mx-auto mb-5">1</div>
          <h3 class="text-lg font-bold text-dark mb-2">Cuéntanos tu necesidad</h3>
          <p class="text-gray-600 text-sm">Analizamos tu negocio y diseñamos el asistente ideal para ti.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary-600 text-white text-xl font-bold flex items-center justify-center mx-auto mb-5">2</div>
          <h3 class="text-lg font-bold text-dark mb-2">Lo construimos y entrenamos</h3>
          <p class="text-gray-600 text-sm">Creamos tu asistente con tu información, marca y personalidad.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary-600 text-white text-xl font-bold flex items-center justify-center mx-auto mb-5">3</div>
          <h3 class="text-lg font-bold text-dark mb-2">Lanza y crece</h3>
          <p class="text-gray-600 text-sm">Tu asistente atiende 24/7 y mejora continuamente con cada conversación.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/como-funciona" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700 transition-colors">
          Conoce el proceso completo
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Verticals -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark mb-4">
          Soluciones para tu industria
        </h2>
        <p class="text-lg text-gray-600">
          Asistentes IA especializados para los retos específicos de tu sector.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {verticals.map((v) => (
          <a href={v.href} class="group block p-8 rounded-2xl border border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-5 group-hover:bg-primary-600 group-hover:text-white transition-colors">
              <Fragment set:html={v.icon} />
            </div>
            <h3 class="text-xl font-bold text-dark mb-2 group-hover:text-primary-600 transition-colors">{v.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{v.description}</p>
            <span class="inline-flex items-center text-sm font-semibold text-primary-600">
              Ver solución
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
