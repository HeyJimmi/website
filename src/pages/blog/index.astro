---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());

const pillars = [
  { id: 'all', label: 'Todos' },
  { id: 'condominios', label: 'Condominios' },
  { id: 'academias', label: 'Academias' },
  { id: 'medios-locales', label: 'Medios locales' },
  { id: 'tecnologia-pymes', label: 'Tech para PyMEs' },
  { id: 'casos-de-exito', label: 'Casos de éxito' },
];

function formatDate(date: string | Date) {
  return new Date(date).toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function pillarLabel(pillar: string) {
  const found = pillars.find((p) => p.id === pillar);
  return found ? found.label : pillar;
}
---

<Layout
  title="Blog — Software y tecnología para PyMEs mexicanas | HeyJimmi"
  description="Artículos sobre tecnología para condominios, academias y medios locales en México. Guías prácticas sin jerigonza técnica."
>
  <section class="pt-28 pb-16 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
          Ideas que le sirven a tu negocio.
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          Sin jerigonza tech. Sin teoría que no aplica. Solo lo que funciona
          para negocios como el tuyo.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-2 mt-10">
        {pillars.map((pillar) => (
          <button
            data-pillar={pillar.id}
            class:list={[
              'pillar-filter rounded-full px-4 py-2 text-sm font-medium transition-colors cursor-pointer',
              pillar.id === 'all'
                ? 'bg-primary-600 text-white'
                : 'bg-white text-gray-600 border border-gray-200 hover:border-primary-200 hover:text-primary-600',
            ]}
          >
            {pillar.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            data-post-pillar={post.data.pillar}
            class="post-card group block rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300"
          >
            <div class="h-48 bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center">
              <svg class="w-16 h-16 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-flex items-center rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700">
                  {pillarLabel(post.data.pillar)}
                </span>
                <time class="text-xs text-gray-500" datetime={new Date(post.data.publishDate).toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
              </div>
              <h2 class="text-lg font-bold text-dark mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-600 line-clamp-3">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-16">
          <p class="text-gray-500 text-lg">Próximamente publicaremos contenido. ¡Vuelve pronto!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  const filters = document.querySelectorAll('.pillar-filter');
  const cards = document.querySelectorAll('.post-card');

  filters.forEach((filter) => {
    filter.addEventListener('click', () => {
      const pillar = filter.getAttribute('data-pillar');

      filters.forEach((f) => {
        f.classList.remove('bg-primary-600', 'text-white');
        f.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      });
      filter.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      filter.classList.add('bg-primary-600', 'text-white');

      cards.forEach((card) => {
        const postPillar = card.getAttribute('data-post-pillar');
        if (pillar === 'all' || postPillar === pillar) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
