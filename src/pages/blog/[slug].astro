---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — HeyJimmi Blog`}
  description={post.data.description}
>
  <article class="pt-28 pb-16 sm:pt-36">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center text-sm text-primary-600 hover:text-primary-700 mb-8 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Volver al blog
      </a>

      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-sm text-gray-500" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="text-gray-300">·</span>
          <span class="text-sm text-gray-500">{post.data.author}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark leading-tight mb-4">
          {post.data.title}
        </h1>
        <p class="text-lg text-gray-600">{post.data.description}</p>
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>
    </div>
  </article>

  <CTASection
    title="¿Tu negocio necesita su propia plataforma?"
    subtitle="Descubre cómo HeyJimmi puede construir la herramienta que tu negocio necesita."
  />
</Layout>
