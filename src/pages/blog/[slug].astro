---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.id !== post.id)
  .filter((p) => p.data.pillar === post.data.pillar)
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
  .slice(0, 3);

const pillarLabels: Record<string, string> = {
  condominios: 'Condominios',
  academias: 'Academias',
  'medios-locales': 'Medios locales',
  'tecnologia-pymes': 'Tech para PyMEs',
  'casos-de-exito': 'Casos de éxito',
};

function formatDate(date: string | Date) {
  return new Date(date).toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function estimateReadTime(content: string) {
  const words = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<Layout
  title={`${post.data.title} | HeyJimmi`}
  description={post.data.description}
>
  <article class="pt-28 pb-16 sm:pt-36">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center text-sm text-primary-600 hover:text-primary-700 mb-8 transition-colors">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Volver al blog
      </a>

      <header class="mb-10">
        <span class="inline-flex items-center rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700 mb-4">
          {pillarLabels[post.data.pillar] || post.data.pillar}
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark leading-tight mb-4">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <time datetime={new Date(post.data.publishDate).toISOString()}>
            {formatDate(post.data.publishDate)}
          </time>
          <span class="text-gray-300">&middot;</span>
          <span>{post.data.author}</span>
        </div>
      </header>

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>
    </div>
  </article>

  <CTASection
    title="¿Quieres que tu negocio tenga su propia plataforma?"
    subtitle="Platícanos. La primera llamada es gratis."
    buttonText="Agenda una demo →"
    buttonHref="/demo"
  />

  {allPosts.length > 0 && (
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold font-heading text-dark mb-8">Artículos relacionados</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {allPosts.map((related) => (
            <a href={`/blog/${related.id}`} class="group block rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg hover:border-primary-200 transition-all duration-300">
              <div class="h-36 bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center">
                <svg class="w-12 h-12 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
              <div class="p-5">
                <h3 class="text-base font-bold text-dark mb-1 group-hover:text-primary-600 transition-colors line-clamp-2">
                  {related.data.title}
                </h3>
                <p class="text-sm text-gray-600 line-clamp-2">{related.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
