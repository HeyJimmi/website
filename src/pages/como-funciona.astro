---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';

const steps = [
  {
    number: '01',
    title: 'Diagnóstico inicial',
    description: 'Analizamos tu negocio, procesos de atención al cliente, preguntas frecuentes y flujos de comunicación. Entendemos tus necesidades específicas.',
    details: ['Entrevista de 30 minutos', 'Análisis de canales actuales', 'Mapeo de preguntas frecuentes', 'Identificación de oportunidades'],
  },
  {
    number: '02',
    title: 'Diseño y entrenamiento',
    description: 'Creamos un asistente personalizado con la personalidad de tu marca. Lo entrenamos con tu información, productos, servicios y políticas.',
    details: ['Personalidad de marca', 'Base de conocimiento', 'Flujos de conversación', 'Pruebas internas'],
  },
  {
    number: '03',
    title: 'Integración y lanzamiento',
    description: 'Conectamos tu asistente a WhatsApp, tu sitio web o cualquier canal que necesites. Lo lanzamos con monitoreo en tiempo real.',
    details: ['WhatsApp Business', 'Widget web', 'Redes sociales', 'CRM y herramientas'],
  },
  {
    number: '04',
    title: 'Optimización continua',
    description: 'Monitoreamos conversaciones, analizamos métricas y optimizamos las respuestas del asistente. Tu bot mejora cada semana.',
    details: ['Reportes semanales', 'Ajustes de respuestas', 'Nuevos flujos', 'Escalamiento a humanos'],
  },
];
---

<Layout
  title="Cómo funciona — HeyJimmi | Asistentes IA para tu negocio"
  description="Descubre cómo HeyJimmi crea e implementa chatbots inteligentes para tu negocio en 4 pasos sencillos."
>
  <section class="pt-28 pb-16 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
          ¿Cómo funciona <span class="text-primary-600">HeyJimmi</span>?
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          En 4 pasos sencillos tendrás un asistente IA atendiendo a tus clientes 24/7. Sin complicaciones técnicas.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {steps.map((step, index) => (
          <div class="flex flex-col md:flex-row gap-8 items-start">
            <div class="flex-shrink-0">
              <span class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-600 text-white text-2xl font-bold">
                {step.number}
              </span>
            </div>
            <div class="flex-1">
              <h2 class="text-2xl font-bold text-dark mb-3">{step.title}</h2>
              <p class="text-gray-600 leading-relaxed mb-4">{step.description}</p>
              <ul class="grid grid-cols-2 gap-2">
                {step.details.map((detail) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-secondary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {detail}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
