---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto — HeyJimmi | Hablemos"
  description="¿Tienes preguntas sobre HeyJimmi? Contáctanos y te ayudamos a encontrar la solución ideal para tu negocio."
>
  <section class="pt-28 pb-20 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="max-w-lg">
          <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
            Hablemos sobre tu <span class="text-primary-600">proyecto</span>
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed mb-10">
            ¿Tienes preguntas? ¿Quieres saber si HeyJimmi es para ti? Escríbenos y te respondemos en menos de 24 horas.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark">Email</h3>
                <p class="text-sm text-gray-600">hola@heyjimmi.com</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="font-bold text-dark">Ubicación</h3>
                <p class="text-sm text-gray-600">Ciudad de México, México</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
          <h2 class="text-2xl font-bold text-dark mb-6">Envíanos un mensaje</h2>
          <form class="space-y-5" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                <input type="text" id="name" name="name" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition" placeholder="Tu nombre" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" id="email" name="email" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition" placeholder="tu@email.com" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Asunto</label>
              <input type="text" id="subject" name="subject" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition" placeholder="¿En qué podemos ayudarte?" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Mensaje</label>
              <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition resize-none" placeholder="Cuéntanos sobre tu proyecto o pregunta..."></textarea>
            </div>
            <button type="submit" class="w-full rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white hover:bg-primary-700 transition-colors">
              Enviar mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
