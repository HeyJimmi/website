---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';

const features = [
  {
    title: 'Información de cursos y programas',
    description: 'Tu plataforma muestra toda tu oferta educativa: horarios, costos, requisitos, modalidades y disponibilidad.',
  },
  {
    title: 'Proceso de inscripción',
    description: 'Guía a los interesados paso a paso en el proceso de inscripción, recopilando datos y documentos necesarios.',
  },
  {
    title: 'Atención a padres de familia',
    description: 'Resuelve dudas de padres sobre horarios, pagos, eventos escolares y comunicados de forma inmediata.',
  },
  {
    title: 'Recordatorios automáticos',
    description: 'Envía recordatorios de pagos, fechas de exámenes, eventos y días festivos a alumnos y padres.',
  },
  {
    title: 'Seguimiento de prospectos',
    description: 'Captura y califica prospectos interesados, con seguimiento organizado hasta la inscripción.',
  },
  {
    title: 'Soporte multicanal',
    description: 'Atiende por WhatsApp, sitio web y redes sociales con la misma calidad y consistencia.',
  },
];

const benefits = [
  { value: '40%', label: 'más conversiones de inscripción' },
  { value: '3x', label: 'más rápido en responder prospectos' },
  { value: '24/7', label: 'atención a padres y alumnos' },
  { value: '50%', label: 'menos carga administrativa' },
];
---

<Layout
  title="HeyJimmi para Academias — Plataforma para Escuelas"
  description="Gestiona inscripciones, atención a padres y comunicación escolar con una plataforma a la medida. Diseñada para academias en México."
>
  <section class="pt-28 pb-16 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700 mb-6">
          Solución para academias
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
          Una plataforma que <span class="text-primary-600">impulsa las inscripciones</span> de tu academia
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          Gestiona inscripciones, mantén informados a padres y alumnos, y organiza toda la operación de tu academia en un solo lugar.
        </p>
        <a href="/demo" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3.5 text-base font-semibold text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-600/25">
          Agenda un demo para academias
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white border-y border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {benefits.map((b) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold font-heading text-primary-600">{b.value}</div>
            <div class="mt-1 text-sm text-gray-500">{b.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark mb-4">
          ¿Qué puede hacer la plataforma por tu academia?
        </h2>
        <p class="text-lg text-gray-600">
          Funcionalidades diseñadas para escuelas, academias de idiomas, deportivas y centros de capacitación.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f) => (
          <div class="p-8 rounded-2xl border border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
            <h3 class="text-lg font-bold text-dark mb-2">{f.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-light">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-extrabold font-heading text-dark mb-6">¿Cómo funciona para academias?</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">1</span>
              <div>
                <h3 class="font-bold text-dark">Nos compartes tu oferta educativa</h3>
                <p class="text-sm text-gray-600">Cursos, horarios, precios, requisitos de inscripción y preguntas frecuentes.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">2</span>
              <div>
                <h3 class="font-bold text-dark">Construimos tu plataforma</h3>
                <p class="text-sm text-gray-600">La diseñamos para que se adapte a tu academia como si fuera hecha por tu propio equipo de tecnología.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">3</span>
              <div>
                <h3 class="font-bold text-dark">Empieza a captar alumnos</h3>
                <p class="text-sm text-gray-600">Tu plataforma organiza prospectos, facilita inscripciones y mantiene todo en orden desde el primer día.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="font-bold text-dark mb-4">Ejemplo de conversación</h3>
          <div class="space-y-3">
            <div class="flex justify-end"><div class="bg-primary-50 text-primary-900 rounded-2xl rounded-tr-sm px-4 py-2 text-sm max-w-[80%]">Hola, ¿tienen clases de inglés para niños?</div></div>
            <div class="flex justify-start"><div class="bg-gray-100 text-gray-800 rounded-2xl rounded-tl-sm px-4 py-2 text-sm max-w-[80%]">¡Hola! Sí, tenemos cursos de inglés para niños de 6 a 12 años. Las clases son los martes y jueves de 4:00 a 5:30 PM. La inscripción es de $500 y la mensualidad de $1,800. ¿Te gustaría agendar una clase muestra gratuita?</div></div>
            <div class="flex justify-end"><div class="bg-primary-50 text-primary-900 rounded-2xl rounded-tr-sm px-4 py-2 text-sm max-w-[80%]">Sí, para mi hijo de 8 años</div></div>
            <div class="flex justify-start"><div class="bg-gray-100 text-gray-800 rounded-2xl rounded-tl-sm px-4 py-2 text-sm max-w-[80%]">Perfecto. La próxima clase muestra es el martes 18 a las 4:00 PM. Solo necesito el nombre de tu hijo y un número de contacto. ¿Me los puedes compartir?</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="¿Listo para llenar tu academia?"
    subtitle="Agenda una demo y te mostramos cómo una plataforma a la medida puede aumentar tus inscripciones."
    buttonText="Agenda demo para academias"
  />
</Layout>
