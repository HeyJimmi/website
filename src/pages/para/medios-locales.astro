---
import Layout from '../../layouts/Layout.astro';
import CTASection from '../../components/CTASection.astro';

const features = [
  {
    title: 'Distribución de noticias por WhatsApp',
    description: 'Envía las noticias más importantes del día directamente al WhatsApp de tus suscriptores, con resúmenes personalizados.',
  },
  {
    title: 'Gestión de suscriptores',
    description: 'Los lectores se suscriben y eligen qué temas les interesan. El asistente gestiona altas, bajas y preferencias.',
  },
  {
    title: 'Alertas de última hora',
    description: 'Envía breaking news y alertas importantes a tu audiencia en segundos, directamente por WhatsApp.',
  },
  {
    title: 'Interacción con la audiencia',
    description: 'Recibe tips de noticias, comentarios y sugerencias de tu comunidad de forma organizada.',
  },
  {
    title: 'Encuestas y votaciones',
    description: 'Lanza encuestas rápidas a tu audiencia sobre temas de interés y obtén retroalimentación en tiempo real.',
  },
  {
    title: 'Monetización',
    description: 'Ofrece contenido premium a suscriptores de pago con gestión automatizada de membresías.',
  },
];

const benefits = [
  { value: '5x', label: 'más engagement que email' },
  { value: '95%', label: 'tasa de apertura en WhatsApp' },
  { value: '10K+', label: 'suscriptores gestionados' },
  { value: '24/7', label: 'distribución automatizada' },
];
---

<Layout
  title="HeyJimmi para Medios Locales — Asistente IA para Noticias"
  description="Distribuye noticias por WhatsApp, gestiona suscriptores y automatiza la interacción con tu audiencia. Diseñado para medios locales en México."
>
  <section class="pt-28 pb-16 sm:pt-36 bg-gradient-to-br from-primary-50 via-white to-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700 mb-6">
          Solución para medios locales
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold font-heading text-dark mb-6">
          Lleva tus noticias a <span class="text-primary-600">donde está tu audiencia</span>
        </h1>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          Distribuye noticias por WhatsApp, gestiona miles de suscriptores y crea una conexión directa con tu comunidad. Todo automatizado con IA.
        </p>
        <a href="/demo" class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3.5 text-base font-semibold text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-600/25">
          Agenda un demo para medios
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white border-y border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {benefits.map((b) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold font-heading text-primary-600">{b.value}</div>
            <div class="mt-1 text-sm text-gray-500">{b.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold font-heading text-dark mb-4">
          ¿Qué puede hacer el asistente por tu medio?
        </h2>
        <p class="text-lg text-gray-600">
          Funcionalidades diseñadas para periódicos digitales, portales de noticias y medios independientes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((f) => (
          <div class="p-8 rounded-2xl border border-gray-100 hover:border-primary-200 hover:shadow-lg transition-all duration-300">
            <h3 class="text-lg font-bold text-dark mb-2">{f.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-light">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-extrabold font-heading text-dark mb-6">¿Cómo funciona para medios?</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">1</span>
              <div>
                <h3 class="font-bold text-dark">Definimos tu estrategia de distribución</h3>
                <p class="text-sm text-gray-600">Tipo de contenido, frecuencia, segmentos de audiencia y canales.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">2</span>
              <div>
                <h3 class="font-bold text-dark">Configuramos tu asistente de noticias</h3>
                <p class="text-sm text-gray-600">Integración con tu CMS, formatos de envío y gestión de suscriptores.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary-600 text-white flex items-center justify-center font-bold">3</span>
              <div>
                <h3 class="font-bold text-dark">Lanza tu canal de WhatsApp</h3>
                <p class="text-sm text-gray-600">Tus lectores se suscriben y empiezan a recibir noticias curadas por IA.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="font-bold text-dark mb-4">Ejemplo de conversación</h3>
          <div class="space-y-3">
            <div class="flex justify-end"><div class="bg-primary-50 text-primary-900 rounded-2xl rounded-tr-sm px-4 py-2 text-sm max-w-[80%]">Hola, quiero suscribirme a las noticias</div></div>
            <div class="flex justify-start"><div class="bg-gray-100 text-gray-800 rounded-2xl rounded-tl-sm px-4 py-2 text-sm max-w-[80%]">¡Bienvenido! ¿Qué temas te interesan? Puedes elegir: 1) Política 2) Deportes 3) Cultura 4) Seguridad 5) Todas las noticias</div></div>
            <div class="flex justify-end"><div class="bg-primary-50 text-primary-900 rounded-2xl rounded-tr-sm px-4 py-2 text-sm max-w-[80%]">Deportes y cultura</div></div>
            <div class="flex justify-start"><div class="bg-gray-100 text-gray-800 rounded-2xl rounded-tl-sm px-4 py-2 text-sm max-w-[80%]">Listo, te enviaremos las noticias más importantes de deportes y cultura cada mañana a las 7:00 AM. También recibirás alertas de última hora. Puedes cambiar tus preferencias en cualquier momento.</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="¿Listo para llegar a más lectores?"
    subtitle="Agenda una demo y te mostramos cómo distribuir noticias por WhatsApp con IA."
    buttonText="Agenda demo para medios"
  />
</Layout>
